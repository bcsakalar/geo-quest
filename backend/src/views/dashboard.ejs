<!-- Dashboard -->
<div class="row g-4 mb-4">
    <!-- Toplam Görev -->
    <div class="col-md-3 col-sm-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-3 bg-primary bg-opacity-10 p-3 me-3">
                    <i class="bi bi-flag-fill text-primary fs-4"></i>
                </div>
                <div>
                    <h3 class="mb-0 fw-bold"><%= stats.totalQuests %></h3>
                    <small class="text-muted">Toplam Görev</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Aktif Görev -->
    <div class="col-md-3 col-sm-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-3 bg-success bg-opacity-10 p-3 me-3">
                    <i class="bi bi-check-circle-fill text-success fs-4"></i>
                </div>
                <div>
                    <h3 class="mb-0 fw-bold"><%= stats.activeQuests %></h3>
                    <small class="text-muted">Aktif Görev</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Kullanıcı Sayısı -->
    <div class="col-md-3 col-sm-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-3 bg-info bg-opacity-10 p-3 me-3">
                    <i class="bi bi-people-fill text-info fs-4"></i>
                </div>
                <div>
                    <h3 class="mb-0 fw-bold"><%= stats.totalUsers %></h3>
                    <small class="text-muted">Kullanıcı</small>
                </div>
            </div>
        </div>
    </div>

    <!-- Bekleyen Gönderim -->
    <div class="col-md-3 col-sm-6">
        <div class="card border-0 shadow-sm h-100">
            <div class="card-body d-flex align-items-center">
                <div class="rounded-3 bg-warning bg-opacity-10 p-3 me-3">
                    <i class="bi bi-hourglass-split text-warning fs-4"></i>
                </div>
                <div>
                    <h3 class="mb-0 fw-bold"><%= stats.pendingSubmissions %></h3>
                    <small class="text-muted">Bekleyen</small>
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Son Gönderimler -->
<div class="card border-0 shadow-sm">
    <div class="card-header bg-white d-flex justify-content-between align-items-center">
        <h5 class="mb-0"><i class="bi bi-inbox me-2"></i>Son Gönderimler</h5>
        <a href="/admin/submissions" class="btn btn-sm btn-outline-success">Tümünü Gör</a>
    </div>
    <div class="card-body p-0">
        <% if (recentSubmissions.length === 0) { %>
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1"></i>
                <p class="mt-2">Henüz gönderim yok</p>
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>Kullanıcı</th>
                            <th>Görev</th>
                            <th>Tip</th>
                            <th>Durum</th>
                            <th>Tarih</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% recentSubmissions.forEach(s => { %>
                            <tr>
                                <td><%= s.user_name %></td>
                                <td><%= s.quest_title %></td>
                                <td>
                                    <% if (s.quest_type === 'photo') { %>
                                        <span class="badge bg-info"><i class="bi bi-camera me-1"></i>Fotoğraf</span>
                                    <% } else if (s.quest_type === 'question') { %>
                                        <span class="badge bg-primary"><i class="bi bi-question-circle me-1"></i>Soru</span>
                                    <% } else { %>
                                        <span class="badge bg-dark"><i class="bi bi-qr-code me-1"></i>QR Kod</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (s.status === 'pending') { %>
                                        <span class="badge bg-warning text-dark">Bekliyor</span>
                                    <% } else if (s.status === 'approved') { %>
                                        <span class="badge bg-success">Onaylandı</span>
                                    <% } else { %>
                                        <span class="badge bg-danger">Reddedildi</span>
                                    <% } %>
                                </td>
                                <td><%= new Date(s.submitted_at).toLocaleDateString('tr-TR') %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>
