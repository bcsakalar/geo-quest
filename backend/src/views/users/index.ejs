<!-- Kullanıcılar -->
<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <% if (users.length === 0) { %>
            <div class="text-center py-5 text-muted">
                <i class="bi bi-people fs-1"></i>
                <p class="mt-2">Henüz kullanıcı yok</p>
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>İsim</th>
                            <th>Email</th>
                            <th>Rol</th>
                            <th>Puan</th>
                            <th>Kayıt Tarihi</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% users.forEach(u => { %>
                            <tr>
                                <td><%= u.id %></td>
                                <td class="fw-semibold"><%= u.name %></td>
                                <td><%= u.email %></td>
                                <td>
                                    <% if (u.role === 'admin') { %>
                                        <span class="badge bg-danger">Admin</span>
                                    <% } else { %>
                                        <span class="badge bg-primary">Kullanıcı</span>
                                    <% } %>
                                </td>
                                <td><span class="badge bg-warning text-dark"><%= u.total_points %> puan</span></td>
                                <td><%= new Date(u.created_at).toLocaleDateString('tr-TR') %></td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>
