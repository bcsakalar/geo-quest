<!-- Görev Düzenle -->
<% if (error) { %>
    <div class="alert alert-danger"><i class="bi bi-exclamation-circle me-1"></i> <%= error %></div>
<% } %>

<div class="row g-4">
    <div class="col-lg-5">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-geo-alt me-2"></i>Konum</h5>
            </div>
            <div class="card-body p-0">
                <div id="map" style="height: 450px; width: 100%;"></div>
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card border-0 shadow-sm">
            <div class="card-header bg-white">
                <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Görev Düzenle</h5>
            </div>
            <div class="card-body">
                <form method="POST" action="/admin/quests/<%= quest.id %>/edit">
                    <div class="mb-3">
                        <label for="title" class="form-label">Başlık <span class="text-danger">*</span></label>
                        <input type="text" class="form-control" id="title" name="title"
                               value="<%= quest.title %>" required>
                    </div>

                    <div class="mb-3">
                        <label for="description" class="form-label">Açıklama</label>
                        <textarea class="form-control" id="description" name="description" rows="3"><%= quest.description || '' %></textarea>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-4">
                            <label for="type" class="form-label">Görev Tipi</label>
                            <select class="form-select" id="type" name="type" required>
                                <option value="photo" <%= quest.type === 'photo' ? 'selected' : '' %>>Fotoğraf Çek</option>
                                <option value="question" <%= quest.type === 'question' ? 'selected' : '' %>>Soru Cevapla</option>
                                <option value="qr_code" <%= quest.type === 'qr_code' ? 'selected' : '' %>>QR Kod Okut</option>
                            </select>
                        </div>
                        <div class="col-md-4">
                            <label for="points" class="form-label">Puan</label>
                            <input type="number" class="form-control" id="points" name="points"
                                   value="<%= quest.points %>" min="1">
                        </div>
                        <div class="col-md-4">
                            <label for="radius_meters" class="form-label">Yarıçap (m)</label>
                            <input type="number" class="form-control" id="radius_meters" name="radius_meters"
                                   value="<%= quest.radius_meters %>" min="10">
                        </div>
                    </div>

                    <div class="row g-3 mb-3">
                        <div class="col-md-6">
                            <label for="latitude" class="form-label">Enlem</label>
                            <input type="text" class="form-control" id="latitude" name="latitude"
                                   value="<%= quest.latitude %>" required readonly>
                        </div>
                        <div class="col-md-6">
                            <label for="longitude" class="form-label">Boylam</label>
                            <input type="text" class="form-control" id="longitude" name="longitude"
                                   value="<%= quest.longitude %>" required readonly>
                        </div>
                    </div>

                    <div id="questionFields" class="<%= quest.type === 'question' ? '' : 'd-none' %>">
                        <div class="mb-3">
                            <label for="question" class="form-label">Soru</label>
                            <input type="text" class="form-control" id="question" name="question"
                                   value="<%= quest.question || '' %>">
                        </div>
                        <div class="mb-3">
                            <label for="answer" class="form-label">Doğru Cevap</label>
                            <input type="text" class="form-control" id="answer" name="answer"
                                   value="<%= quest.answer || '' %>">
                        </div>
                    </div>

                    <div id="qrFields" class="<%= quest.type === 'qr_code' ? '' : 'd-none' %>">
                        <div class="mb-3">
                            <label for="qr_data" class="form-label">Beklenen QR Verisi</label>
                            <input type="text" class="form-control" id="qr_data" name="qr_data"
                                   value="<%= quest.qr_data || '' %>">
                        </div>
                    </div>

                    <div class="mb-3 form-check form-switch">
                        <input class="form-check-input" type="checkbox" id="is_active" name="is_active"
                               <%= quest.is_active ? 'checked' : '' %>>
                        <label class="form-check-label" for="is_active">Aktif</label>
                    </div>

                    <div class="d-flex gap-2">
                        <button type="submit" class="btn btn-success flex-grow-1 py-2">
                            <i class="bi bi-check-circle me-1"></i> Kaydet
                        </button>
                        <a href="/admin/quests" class="btn btn-outline-secondary py-2">İptal</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

<script>
document.addEventListener('DOMContentLoaded', function() {
    const lat = parseFloat('<%= quest.latitude %>');
    const lng = parseFloat('<%= quest.longitude %>');

    const map = L.map('map').setView([lat, lng], 14);
    L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
        attribution: '&copy; OpenStreetMap contributors'
    }).addTo(map);

    let marker = L.marker([lat, lng], { draggable: true }).addTo(map);

    marker.on('dragend', function(ev) {
        const pos = ev.target.getLatLng();
        document.getElementById('latitude').value = pos.lat.toFixed(6);
        document.getElementById('longitude').value = pos.lng.toFixed(6);
    });

    map.on('click', function(e) {
        marker.setLatLng(e.latlng);
        document.getElementById('latitude').value = e.latlng.lat.toFixed(6);
        document.getElementById('longitude').value = e.latlng.lng.toFixed(6);
    });

    const typeSelect = document.getElementById('type');
    const questionFields = document.getElementById('questionFields');
    const qrFields = document.getElementById('qrFields');
    typeSelect.addEventListener('change', function() {
        questionFields.classList.toggle('d-none', this.value !== 'question');
        qrFields.classList.toggle('d-none', this.value !== 'qr_code');
    });
});
</script>
