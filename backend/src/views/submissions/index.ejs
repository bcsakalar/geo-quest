<!-- Gönderimler -->
<div class="d-flex gap-2 mb-4">
    <a href="/admin/submissions" class="btn btn-sm <%= filterStatus === 'all' ? 'btn-success' : 'btn-outline-secondary' %>">Tümü</a>
    <a href="/admin/submissions?status=pending" class="btn btn-sm <%= filterStatus === 'pending' ? 'btn-warning' : 'btn-outline-secondary' %>">Bekleyen</a>
    <a href="/admin/submissions?status=approved" class="btn btn-sm <%= filterStatus === 'approved' ? 'btn-success' : 'btn-outline-secondary' %>">Onaylanan</a>
    <a href="/admin/submissions?status=rejected" class="btn btn-sm <%= filterStatus === 'rejected' ? 'btn-danger' : 'btn-outline-secondary' %>">Reddedilen</a>
</div>

<div class="card border-0 shadow-sm">
    <div class="card-body p-0">
        <% if (submissions.length === 0) { %>
            <div class="text-center py-5 text-muted">
                <i class="bi bi-inbox fs-1"></i>
                <p class="mt-2">Gönderim bulunamadı</p>
            </div>
        <% } else { %>
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0">
                    <thead class="table-light">
                        <tr>
                            <th>#</th>
                            <th>Kullanıcı</th>
                            <th>Görev</th>
                            <th>Tip</th>
                            <th>İçerik</th>
                            <th>Durum</th>
                            <th>Tarih</th>
                            <th class="text-end">İşlemler</th>
                        </tr>
                    </thead>
                    <tbody>
                        <% submissions.forEach(s => { %>
                            <tr>
                                <td><%= s.id %></td>
                                <td>
                                    <strong><%= s.user_name %></strong>
                                    <br><small class="text-muted"><%= s.user_email %></small>
                                </td>
                                <td><%= s.quest_title %></td>
                                <td>
                                    <% if (s.quest_type === 'photo') { %>
                                        <span class="badge bg-info"><i class="bi bi-camera me-1"></i>Fotoğraf</span>
                                    <% } else if (s.quest_type === 'question') { %>
                                        <span class="badge bg-primary"><i class="bi bi-question-circle me-1"></i>Soru</span>
                                    <% } else { %>
                                        <span class="badge bg-dark"><i class="bi bi-qr-code me-1"></i>QR Kod</span>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (s.photo_url) { %>
                                        <a href="<%= s.photo_url %>" target="_blank" class="btn btn-sm btn-outline-info">
                                            <i class="bi bi-image me-1"></i>Fotoğraf
                                        </a>
                                    <% } %>
                                    <% if (s.answer_text) { %>
                                        <span class="badge bg-light text-dark">Cevap: <%= s.answer_text %></span>
                                    <% } %>
                                    <% if (s.qr_scanned_data) { %>
                                        <span class="badge bg-light text-dark">QR: <%= s.qr_scanned_data %></span>
                                    <% } %>
                                    <% if (s.ai_score != null) { %>
                                        <br><span class="badge <%= s.ai_score >= 70 ? 'bg-success' : 'bg-warning text-dark' %>">AI: <%= s.ai_score %>/100</span>
                                        <% if (s.ai_evaluation) { %>
                                            <small class="text-muted d-block" style="max-width:200px;"><%= s.ai_evaluation.substring(0, 80) %><%= s.ai_evaluation.length > 80 ? '...' : '' %></small>
                                        <% } %>
                                    <% } %>
                                </td>
                                <td>
                                    <% if (s.status === 'pending') { %>
                                        <span class="badge bg-warning text-dark">Bekliyor</span>
                                    <% } else if (s.status === 'approved') { %>
                                        <span class="badge bg-success">Onaylandı</span>
                                    <% } else { %>
                                        <span class="badge bg-danger">Reddedildi</span>
                                    <% } %>
                                </td>
                                <td><%= new Date(s.submitted_at).toLocaleDateString('tr-TR') %></td>
                                <td class="text-end">
                                    <% if (s.status === 'pending') { %>
                                        <form method="POST" action="/admin/submissions/<%= s.id %>/approve" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-success me-1" title="Onayla">
                                                <i class="bi bi-check-lg"></i>
                                            </button>
                                        </form>
                                        <form method="POST" action="/admin/submissions/<%= s.id %>/reject" class="d-inline">
                                            <button type="submit" class="btn btn-sm btn-danger" title="Reddet">
                                                <i class="bi bi-x-lg"></i>
                                            </button>
                                        </form>
                                    <% } else { %>
                                        <span class="text-muted">—</span>
                                    <% } %>
                                </td>
                            </tr>
                        <% }) %>
                    </tbody>
                </table>
            </div>
        <% } %>
    </div>
</div>
